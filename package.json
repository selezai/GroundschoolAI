    "pdfjs-dist": "^4.0.379",
    "react": "18.3.1",
    "react-dom": "18.2.0",
    "react-native": "0.76.3",
    "react-native-document-picker": "^9.3.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^7.2.2",
    "react-native-paystack-webview": "^4.3.1",
